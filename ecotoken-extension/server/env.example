# Create a .env file under server/ (copy this file: cp env.example .env or copy env.example .env)
# Fill in real values — never commit .env

PORT=3001

# Snowflake account values: run this in a SQL worksheet, then map results into the two vars below:
#   select current_organization_name(), current_account_name(), current_account(), current_region();
# SNOWFLAKE_HTTP_ACCOUNT → often lowercase "<org>-<account>" from Snowsight (app.snowflake.com/<ORG>/<ACCOUNT>/...)
# SNOWFLAKE_ACCOUNT      → often the value from current_account() (used in JWT; may differ from HTTP host prefix)
SNOWFLAKE_HTTP_ACCOUNT=your-org-youraccount
SNOWFLAKE_ACCOUNT=YOUR_ACCOUNT_ID

SNOWFLAKE_USER=ECOTOKEN_USER

# Key fingerprint: generate keys first (see below), then SHA256 fingerprint for this user in Snowflake.
SNOWFLAKE_PUBLIC_KEY_FP=SHA256:YOUR_FINGERPRINT_FROM_OPENSSL

SNOWFLAKE_WAREHOUSE=ECOTOKEN_WH
SNOWFLAKE_DATABASE=ECOTOKEN_DB
SNOWFLAKE_SCHEMA=ECOTOKEN
SNOWFLAKE_LOG_SCHEMA=ECOTOKEN
SNOWFLAKE_ROLE=ECOTOKEN_ROLE

# RSA keypair for ECOTOKEN_USER (run from server/):
#   openssl genrsa -out rsa_key.p8 2048
#   openssl rsa -in rsa_key.p8 -pubout -out rsa_key.pub
SF_PRIVATE_KEY_PATH=./rsa_key.p8
# SF_PRIVATE_KEY_PASSPHRASE=

# Optional:
# NODE_ENV=production
# EXTENSION_ID=
# ALLOW_ORIGIN=
